#!/bin/sh
# Build the macOS Hosts3D binary into Release/macos/<arch> or Debug/macos/<arch>.
# This is a quick local helper script for macOS development builds.
set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
cd "$SCRIPT_DIR"

CONFIG="${1:-Release}"
case "$CONFIG" in
  Release|Debug) ;;
  *)
    echo "Usage: $(basename "$0") [Release|Debug]" >&2
    exit 1
    ;;
esac

MACHINE=$(g++ -dumpmachine 2>/dev/null || uname -m)
case "$MACHINE" in
  *x86_64*|*amd64*) ARCH="x64" ;;
  *aarch64*|*arm64*) ARCH="arm64" ;;
  *i?86*|*x86*) ARCH="x86" ;;
  *) ARCH="$MACHINE" ;;
esac

OUTDIR="$CONFIG/macos/$ARCH"
mkdir -p "$OUTDIR"

CXXFLAGS="-std=gnu++11 -Wall -O2"
GLFW_CFLAGS="$(pkg-config --cflags glfw3 2>/dev/null || true)"
GLFW_LIBS="$(pkg-config --libs glfw3 2>/dev/null || printf '%s' '-lglfw -framework Cocoa -framework OpenGL')"

g++ $CXXFLAGS $GLFW_CFLAGS -c -o src/llist.o src/llist.cpp
g++ $CXXFLAGS $GLFW_CFLAGS -c -o src/misc.o src/misc.cpp
g++ $CXXFLAGS $GLFW_CFLAGS -c -o src/glwin.o src/glwin.cpp
g++ $CXXFLAGS $GLFW_CFLAGS -c -o src/objects.o src/objects.cpp
g++ $CXXFLAGS $GLFW_CFLAGS -c -o src/hosts3d.o src/hosts3d.cpp
g++ $CXXFLAGS -o "$OUTDIR/hosts3d" src/llist.o src/misc.o src/glwin.o src/objects.o src/hosts3d.o $GLFW_LIBS
echo "Built $OUTDIR/hosts3d"
