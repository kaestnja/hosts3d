#!/bin/sh
# Build the Linux Hosts3D binary into Release/linux/<arch> or Debug/linux/<arch>.
# This is a quick local helper script, not the autotools install path.
set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
cd "$SCRIPT_DIR"

CONFIG="${1:-Release}"
case "$CONFIG" in
  Release|Debug) ;;
  *)
    echo "Usage: $(basename "$0") [Release|Debug]" >&2
    exit 1
    ;;
esac

MACHINE=$(g++ -dumpmachine 2>/dev/null || uname -m)
case "$MACHINE" in
  *x86_64*|*amd64*) ARCH="x64" ;;
  *aarch64*|*arm64*) ARCH="arm64" ;;
  *i?86*|*x86*) ARCH="x86" ;;
  *) ARCH="$MACHINE" ;;
esac

OUTDIR="$CONFIG/linux/$ARCH"
mkdir -p "$OUTDIR"

g++ -Wall -O2 -c -o src/llist.o src/llist.cpp
g++ -Wall -O2 -c -o src/misc.o src/misc.cpp
g++ -Wall -O2 -c -o src/glwin.o src/glwin.cpp
g++ -Wall -O2 -c -o src/objects.o src/objects.cpp
g++ -Wall -O2 -c -o src/hosts3d.o src/hosts3d.cpp
g++ -Wall -O2 -o "$OUTDIR/hosts3d" src/llist.o src/misc.o src/glwin.o src/objects.o src/hosts3d.o -lglfw -lGL -lGLU
echo "Built $OUTDIR/hosts3d"
